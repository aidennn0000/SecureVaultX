# =============================
# Copy Password
# =============================

def copy_password():

    password = password_var.get()

    if not password:
        messagebox.showwarning(
            "Warning",
            "Generate a password first."
        )
        return

    root.clipboard_clear()
    root.clipboard_append(password)

    messagebox.showinfo(
        "Copied",
        "Password copied to clipboard!"
    )


tk.Button(
    card,
    text="📋 Copy Password",
    width=25,
    command=copy_password
).pack(pady=5)
