import tkinter as tk
from tkinter import messagebox
import sqlite3
import os
import sys
from cryptography.fernet import Fernet
import secrets
import string

BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.append(BASE_DIR)

from theme import *

DB_PATH = os.path.join(BASE_DIR, "database", "vault.db")

# Load encryption key
KEY_PATH = os.path.join(BASE_DIR, "secret.key")

with open(KEY_PATH, "rb") as f:
    key = f.read()

cipher = Fernet(key)


# -------------------------
# PASSWORD STRENGTH
# -------------------------
def check_strength(event=None):

    password = password_entry.get()

    score = 0

    if len(password) >= 8:
        score += 1

    if any(c.isupper() for c in password):
        score += 1

    if any(c.islower() for c in password):
        score += 1

    if any(c.isdigit() for c in password):
        score += 1

    if any(not c.isalnum() for c in password):
        score += 1

    if score <= 2:
        strength_label.config(text="Weak", fg="red")

    elif score <= 4:
        strength_label.config(text="Medium", fg="orange")

    else:
        strength_label.config(text="Strong", fg="green")


# -------------------------
# SHOW PASSWORD
# -------------------------
showing = False

def toggle_password():
    global showing

    if showing:
        password_entry.config(show="*")
        show_btn.config(text="Show")
        showing = False
    else:
        password_entry.config(show="")
        show_btn.config(text="Hide")
        showing = True


# -------------------------
# CLEAR FORM
# -------------------------
def clear_form():

    website_entry.delete(0, tk.END)
    username_entry.delete(0, tk.END)
    password_entry.delete(0, tk.END)
    notes_text.delete("1.0", tk.END)

    strength_label.config(text="-")


# -------------------------
# SAVE PASSWORD
# -------------------------
def save_password():

    website = website_entry.get().strip()
    username = username_entry.get().strip()
    password = password_entry.get().strip()

    if not website or not username or not password:
        messagebox.showerror(
            "Error",
            "All fields are required."
        )
        return

    encrypted = cipher.encrypt(password.encode())

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    cursor.execute(
        """
        INSERT INTO vault
        (website, username, encrypted_password)
        VALUES (?, ?, ?)
        """,
        (
            website,
            username,
            encrypted
        )
    )

    conn.commit()
    conn.close()

    messagebox.showinfo(
        "Success",
        "Password encrypted and saved successfully!"
    )

    clear_form()


# -------------------------
# BACK
# -------------------------
def back_dashboard():
    root.destroy()
    subprocess.Popen(["python3", "dashboard_gui_v2.py"])


# -------------------------
# WINDOW
# -------------------------
root = tk.Tk()
root.title("SecureVaultX")
root.geometry("700x650")
root.configure(bg=BACKGROUND)
root.resizable(False, False)


card = tk.Frame(
    root,
    bg="white",
    padx=30,
    pady=30
)

card.pack(padx=40, pady=30, fill="both", expand=True)

tk.Label(
    card,
    text="🔐 Add New Password",
    font=("Segoe UI", 20, "bold"),
    bg="white",
    fg=TEXT
).pack(pady=10)


# WEBSITE

tk.Label(
    card,
    text="🌐 Website",
    bg="white",
    anchor="w"
).pack(fill="x")

website_entry = tk.Entry(
    card,
    font=("Segoe UI",11)
)

website_entry.pack(fill="x", pady=5)


# USERNAME

tk.Label(
    card,
    text="👤 Username / Email",
    bg="white"
).pack(fill="x", pady=(10,0))

username_entry = tk.Entry(
    card,
    font=("Segoe UI",11)
)

username_entry.pack(fill="x", pady=5)


# PASSWORD

tk.Label(
    card,
    text="🔒 Password",
    bg="white"
).pack(fill="x", pady=(10,0))

frame = tk.Frame(card, bg="white")
frame.pack(fill="x")

password_entry = tk.Entry(
    frame,
    show="*",
    font=("Segoe UI",11)
)

password_entry.pack(side="left", fill="x", expand=True)

password_entry.bind("<KeyRelease>", check_strength)

show_btn = tk.Button(
    frame,
    text="Show",
    command=toggle_password
)

show_btn.pack(side="left", padx=5)


# STRENGTH

tk.Label(
    card,
    text="Password Strength",
    bg="white"
).pack(fill="x", pady=(15,0))

strength_label = tk.Label(
    card,
    text="-",
    bg="white",
    font=("Segoe UI",11,"bold")
)

strength_label.pack(anchor="w")


# NOTES

tk.Label(
    card,
    text="📝 Notes",
    bg="white"
).pack(fill="x", pady=(15,0))

notes_text = tk.Text(
    card,
    height=5,
    font=("Segoe UI",10)
)

notes_text.pack(fill="x")


# BUTTONS

button_frame = tk.Frame(card, bg="white")
button_frame.pack(pady=20)

tk.Button(
    button_frame,
    text="💾 Save",
    bg=PRIMARY,
    fg="white",
    width=15,
    command=save_password
).grid(row=0,column=0,padx=10)

tk.Button(
    button_frame,
    text="🧹 Clear",
    width=15,
    command=clear_form
).grid(row=0,column=1,padx=10)

tk.Button(
    button_frame,
    text="🏠 Dashboard",
    bg=DANGER,
    fg="white",
    width=15,
    command=back_dashboard
).grid(row=0,column=2,padx=10)


root.mainloop()
